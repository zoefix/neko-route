{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Neko Route",
  "version": "0.1.6",
  "identifier": "dev.neko.route",
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Neko Route",
        "width": 1280,
        "height": 820,
        "minWidth": 1060,
        "minHeight": 680,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 18,
          "y": 18
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Local AI model router for Codex",
    "longDescription": "Neko Route routes Codex model requests to configurable AI providers while keeping secrets in the system keychain."
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY3MUU3QUYyOTYyRDQ3MUIKUldRYlJ5Mlc4bm9lWnp0N2lncFNtMzVjbS9jekJCYjFYNkhpSlVxMWdJYlpIRTUrLzIwWUpsTVYK",
      "endpoints": [
        "https://github.com/zoefix/neko-route/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
